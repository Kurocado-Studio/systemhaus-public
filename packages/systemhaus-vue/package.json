{
  "name": "@kurocado-studio/systemhaus-public-vue",
  "version": "0.0.0-semantically-released",
  "private": false,
  "publishConfig": {
    "access": "restricted"
  },
  "type": "module",
  "main": "./dist/exports.js",
  "module": "./dist/exports.js",
  "types": "./dist/exports.d.ts",
  "exports": {
    ".": {
      "types": "./dist/exports.d.ts",
      "import": "./dist/exports.js",
      "default": "./dist/exports.js"
    },
    "./main.css": {
      "import": "./dist/main.css",
      "default": "./dist/main.css"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "vue:dev": "vite",
    "build:vite": "vue-tsc -p tsconfig.json --noEmit && vite build",
    "build": "tsup && vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly --noEmit false --outDir dist",
    "preview": "vite preview",
    "dev": "storybook dev -p 8009 --no-open",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@internal/storybook-config": "workspace:0.0.0-semantically-released",
    "@kurocado-studio/systemhaus-ui": "workspace:0.0.0-semantically-released",
    "@tailwindcss/vite": "^4.2.0",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.574.0",
    "reka-ui": "^2.8.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.2.0",
    "vue": "^3.5.25"
  }
}
