{
  "name": "@kurocado-studio/systemhaus-public-react",
  "version": "0.0.0-semantically-released",
  "private": false,
  "publishConfig": {
    "access": "restricted"
  },
  "type": "module",
  "main": "./dist/exports.js",
  "module": "./dist/exports.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/exports.js",
      "default": "./dist/exports.js"
    },
    "./main.css": {
      "import": "./dist/main.css",
      "default": "./dist/main.css"
    }
  },
  "scripts": {
    "react:dev": "vite",
    "build:vite": "tsc -p tsconfig.json --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev": "storybook dev -p 8008 --no-open",
    "build-storybook": "storybook build",
    "build": "tsup && pnpm build:typings && rm -rf dist/exports.d.ts",
    "build:typings": "api-extractor run --local"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@kurocado-studio/axios-react": "1.1.2-develop.2",
    "@kurocado-studio/systemhaus-ui": "workspace:0.0.0-semantically-released",
    "@phosphor-icons/react": "^2.1.10",
    "motion": "^12.35.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.1",
    "@internal/storybook-config": "workspace:0.0.0-semantically-released",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-vitest": "^10.2.10",
    "@storybook/react-vite": "^10.2.10",
    "@tailwindcss/postcss": "^4.2.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.2.10",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "storybook": "^10.2.10",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
