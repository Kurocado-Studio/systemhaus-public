{
  "name": "@kurocado-studio/systemhaus-public-monorepo",
  "version": "0.0.0-semantically-released",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "build": "turbo run build --concurrency=20",
    "clean": "turbo run clean --concurrency=20 && rm -rf .turbo node_modules pnpm-lock.yaml && pnpm i && pnpm build",
    "commitlint": "pnpm exec commitlint --edit .git/COMMIT_EDITMSG",
    "dev": "turbo run dev --concurrency=20",
    "storybook:dev": "turbo run storybook:dev --concurrency=18",
    "format": "prettier --write .",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "prepare": "husky install",
    "prettier:check": "prettier --check . --ignore-path .prettierignore && turbo run prettier:check",
    "prettier:fix": "prettier --check --write . --ignore-path .prettierignore && turbo run prettier:fix",
    "preview-storybook": "turbo run preview-storybook",
    "semantic-release": "pnpm -r --workspace-concurrency=1 exec -- npx --no-install semantic-release -e semantic-release-monorepo",
    "setup": "pnpm clean && pnpm i && pnpm build",
    "dev:local": "pnpm build && pnpm i && pnpm dev",
    "relink": "pnpm i && pnpm build",
    "typecheck": "turbo run typecheck",
    "preflight": "pnpm setup && pnpm prettier:fix && pnpm lint:fix && pnpm lint && pnpm typecheck",
    "typecheck:monorepo": "pnpm prettier:fix && pnpm lint:fix && pnpm lint && pnpm typecheck",
    "test": "turbo run test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/js": "^9.39.1",
    "@flydotio/dockerfile": "^0.7.10",
    "@internal/config": "workspace:*",
    "@kurocado-studio/qa": "2.0.1",
    "@kurocado-studio/styleguide": "2.6.0-develop.17",
    "@microsoft/api-extractor": "^7.52.11",
    "@storybook/addon-a11y": "^10.1.10",
    "@storybook/addon-docs": "^10.1.10",
    "@storybook/addon-vitest": "^10.1.10",
    "@storybook/react": "^8.6.13",
    "@storybook/react-vite": "^10.1.10",
    "@storybook/vue3-vite": "^10.1.10",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/express": "^4.17.13",
    "@types/jest": "29.5.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "@vue/compiler-sfc": "^3.5.14",
    "@vue/tsconfig": "^0.8.1",
    "chromatic": "^13.3.4",
    "commitlint": "^19.8.1",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "eslint": "9.31",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.1.10",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "29.5.0",
    "lint-staged": "^16.1.6",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "semantic-release": "^24.2.3",
    "semantic-release-monorepo": "^8.0.2",
    "source-map-support": "^0.5.20",
    "storybook": "^10.1.10",
    "storybook-addon-react-docgen": "^1.2.44",
    "supertest": "^6.1.3",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "29.1.0",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "4.2.0",
    "tsup": "^8.5.0",
    "turbo": "^2.5.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "unplugin-vue": "^6.2.0",
    "vite": "^7.2.4",
    "vite-node": "1.6.1",
    "vite-plugin-dts": "^4.5.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.16",
    "vitest-axe": "^0.1.0",
    "vue": "^3.5.14",
    "eslint-config-next": "^15",
    "sharp": "0.34.3",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.4"
  },
  "lint-staged": {
    "*": [
      "prettier --write"
    ],
    "**/*.{ts,tsx}": [
      "prettier --write",
      "turbo run lint:fix --",
      "turbo run lint --"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.10",
    "vite": "5.2.8",
    "typescript": "5.1.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "framer-motion": "^12.23.24"
  },
  "dependencies": {
    "semantic-release-monorepo": "^8.0.2"
  }
}
